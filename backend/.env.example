# Jobify backend environment configuration (copy to .env and fill in)

# --- Security ---
# 32+ byte random string used to encrypt sensitive at-rest values.
ENCRYPTION_SECRET=change-me-to-a-long-random-secret
# Secret used to sign JWT access tokens.
JWT_SECRET=change-me-to-a-long-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- External APIs ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
GEMINI_API_KEY=

# --- Storage ---
DATABASE_PATH=jobify.db

# --- Runtime ---
LOG_LEVEL=INFO
# Optional shared API key for the APIKeyMiddleware gate.
API_KEY=
